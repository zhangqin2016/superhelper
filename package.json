{
  "name": "lily-workbench",
  "version": "0.1.0",
  "private": true,
  "description": "智能工作台桌面客户端",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "DEV_USE_SYSTEM_AGENT=1 electron .",
    "test:unit": "node scripts/test-agent-runner.mjs && node scripts/test-runtime-python.mjs && node scripts/test-spawn-env-runtime.mjs && node scripts/test-locale-settings.mjs && node scripts/test-data-migration.mjs",
    "sync:skills-catalog": "node scripts/sync-skills-catalog.mjs",
    "sync:skills-bundle": "node scripts/sync-skills-catalog.mjs --bundle-only",
    "generate:skill-i18n": "node scripts/generate-skill-i18n.mjs",
    "build:runtime": "node scripts/build-runtime-bundle.mjs",
    "verify:runtime": "node scripts/verify-runtime-bundle.mjs",
    "icon:optimize": "node scripts/optimize-icon.mjs",
    "rebuild:pty": "node scripts/rebuild-pty.mjs",
    "pack": "electron-builder --dir",
    "dist:mac": "node scripts/verify-runtime-bundle.mjs && electron-builder --mac && node scripts/build-mac-dmg.mjs && node scripts/verify-mac-dmg.mjs",
    "dist:win": "node scripts/verify-runtime-bundle.mjs --platform win32-x64 && bash scripts/dist-win.sh",
    "dist:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.company.ai-super-terminal",
    "productName": "智能工作台",
    "directories": {
      "buildResources": "resources"
    },
    "asar": true,
    "asarUnpack": [
      "bundles/**"
    ],
    "extraResources": [
      {
        "from": "bundles",
        "to": "bundles",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "src/**/*",
      "resources/**/*",
      "scripts/**/*",
      "bundles/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "icon": "icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "zip",
        "dir"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "title": "${productName}-${version}",
      "format": "UDZO",
      "sign": false
    },
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "智能工作台",
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052"
    }
  },
  "dependencies": {
    "dompurify": "^3.4.5",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.4"
  },
  "devDependencies": {
    "electron": "^41.7.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  }
}
